---
import Base from '../layouts/Base.astro';
---
<Base
  title="Purchase Confirmed"
  description="Your purchase of Alpha Factory Research #001 is confirmed."
>
  <meta name="robots" content="noindex,nofollow">

  <h1>Payment received — thank you.</h1>
  <p>Your files are delivered by Lemon Squeezy.</p>

  <div style="margin:2rem 0;padding:1.5rem;background:#fafafa;border-radius:8px;">
    <h2 style="margin-top:0;">How to get your report</h2>
    <ol>
      <li>Check the <strong>download button</strong> on the Lemon Squeezy confirmation page.</li>
      <li>Open the <strong>receipt email</strong> from Lemon Squeezy — it contains your download link.</li>
      <li>If you don't see the email, check spam or promotions folder.</li>
    </ol>
  </div>

  <p>Questions or issues? <a href="mailto:support@yijigao.com">support@yijigao.com</a> — we respond within 24 hours.</p>

  <p style="margin-top:2rem;"><a href="/">← Back to Alpha Factory Research</a></p>
</Base>
