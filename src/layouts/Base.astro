---
export interface Props { title: string; description?: string; }
const { title, description } = Astro.props;
const fullTitle = `${title} — Alpha Factory Research`;
const metaDesc = description || 'Independent quantitative research for systematic traders.';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDesc} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Alpha Factory Research" />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  <style is:global>
    @import '/src/styles/global.css';
  </style>
</head>
<body>
  <header style="max-width:720px;margin:0 auto;padding:1.5rem 1.5rem 0;display:flex;justify-content:space-between;align-items:center;">
    <a href="/" style="font-weight:700;font-size:1.1rem;text-decoration:none;color:var(--color-text);">Alpha Factory Research</a>
    <nav style="display:flex;gap:1.5rem;">
      <a href="/about" style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;">About</a>
      <a href="/research" style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;">Research</a>
    </nav>
  </header>
  <main><slot /></main>
  <footer style="max-width:720px;margin:0 auto;padding:2rem 1.5rem 4rem;border-top:1px solid var(--color-border);font-size:0.8125rem;color:var(--color-muted);display:flex;gap:2rem;flex-wrap:wrap;">
    <a href="/privacy">Privacy</a>
    <a href="/refund">Refund</a>
    <a href="mailto:support@yijigao.com">support@yijigao.com</a>
  </footer>
</body>
</html>
